{% assign product_one = product %}
{% assign variant_one = product_one.selected_or_first_available_variant %}
{% assign product_two = product_one %}
{% assign product_three = product_one %}
{% assign bundle_item_count = block.settings.bundle_item_count | default: '3' %}
{% assign item_two_enabled = false %}
{% assign item_three_enabled = false %}

{% if bundle_item_count == '2' or bundle_item_count == '3' %}
  {% assign item_two_enabled = true %}
{% endif %}

{% if bundle_item_count == '3' %}
  {% assign item_three_enabled = true %}
{% endif %}

{% assign variant_two = blank %}
{% assign variant_three = blank %}

{% if item_two_enabled %}
  {% assign variant_two = variant_one %}
{% endif %}

{% if item_three_enabled %}
  {% assign variant_three = variant_one %}
{% endif %}

{% assign subtotal_offer_1 = variant_one.price %}
{% assign subtotal_offer_2 = subtotal_offer_1 %}
{% assign subtotal_offer_3 = subtotal_offer_2 %}

{% if item_two_enabled and variant_two %}
  {% assign subtotal_offer_2 = subtotal_offer_1 | plus: variant_two.price %}
  {% assign subtotal_offer_3 = subtotal_offer_2 %}
{% endif %}

{% if item_three_enabled and variant_three %}
  {% assign subtotal_offer_3 = subtotal_offer_2 | plus: variant_three.price %}
{% endif %}

{% assign discount_2 = block.settings.discount_percent_2 | default: 0 %}
{% assign discount_3 = block.settings.discount_percent_3 | default: 0 %}
{% assign discount_amount_2 = subtotal_offer_2 | times: discount_2 | divided_by: 100 %}
{% assign discount_amount_3 = subtotal_offer_3 | times: discount_3 | divided_by: 100 %}
{% assign final_offer_2 = subtotal_offer_2 | minus: discount_amount_2 %}
{% assign final_offer_3 = subtotal_offer_3 | minus: discount_amount_3 %}

<div
  class="bundle-widget bundle-widget--{{ block.settings.design_preset }}"
  id="bundle-widget-{{ block.id }}"
  {{ block.shopify_attributes }}
  style="
    --bundle-accent-base: {{ block.settings.primary_color }};
    --bundle-bg: color-mix(in srgb, {{ block.settings.primary_color }} 20%, white);
    --bundle-bg-selected: color-mix(in srgb, {{ block.settings.primary_color }} 30%, white);
    --bundle-border: color-mix(in srgb, {{ block.settings.primary_color }} 22%, white);
    --bundle-input: color-mix(in srgb, {{ block.settings.primary_color }} 42%, white);
    --bundle-text: {{ block.settings.text_color }};
    --bundle-heading-size: {{ block.settings.heading_size }}px;
    --bundle-subheading-size: {{ block.settings.subheading_size }}px;
    --bundle-offer-title-size: {{ block.settings.offer_title_size }}px;
    --bundle-offer-price-size: {{ block.settings.offer_price_size }}px;
    --bundle-card-gap: {{ block.settings.card_gap }}px;
    --bundle-card-padding: {{ block.settings.card_padding }}px;
    --bundle-card-radius: 24px;
    --bundle-bestseller-bg: {{ block.settings.best_seller_badge_color }};
    --bundle-bestseller-text: {{ block.settings.best_seller_badge_text_color }};
    --bundle-save-bg: {{ block.settings.save_badge_color }};
    --bundle-save-text: {{ block.settings.save_badge_text_color }};
    --bundle-timer-bg: {{ block.settings.timer_background_color }};
    --bundle-timer-text: {{ block.settings.timer_text_color }};
  "
>
  {% if block.settings.eyebrow != blank or block.settings.heading != blank %}
    <div class="bundle-widget__header">
      {% if block.settings.eyebrow != blank %}
        <p class="bundle-widget__eyebrow">{{ block.settings.eyebrow }}</p>
      {% endif %}
      {% if block.settings.heading != blank %}
        <h2 class="bundle-widget__title">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="bundle-widget__subheading">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% if block.settings.show_timer and block.settings.timer_end != blank %}
    <div
      class="bundle-widget__timer"
      data-bundle-timer
      data-end="{{ block.settings.timer_end | escape }}"
      data-prefix="{{ block.settings.timer_prefix | escape }}"
      data-expired-label="{{ block.settings.timer_expired_text | escape }}"
    >
      <span class="bundle-widget__timer-label">{{ block.settings.timer_prefix }}</span>
      <span class="bundle-widget__timer-value">--:--:--</span>
    </div>
  {% endif %}

  <div class="bundle-dynamic-root" id="bundle-dynamic-root-{{ block.id }}" hidden></div>

  <div class="bundle-static-root" data-static-root>
  <div class="bundle-offers">
    <div
      class="bundle-offer is-selected"
      data-item-count="1"
      data-discount="0"
      role="button"
      tabindex="0"
      aria-pressed="true"
    >
      <div class="bundle-offer__summary">
        <div class="bundle-offer__summary-left">
          {% assign image_one = variant_one.featured_image | default: product_one.featured_image %}
          <div class="bundle-offer__thumb-wrap">
            {% if image_one %}
              <img
                class="bundle-offer__thumb"
                src="{{ image_one | image_url: width: 220 }}"
                alt="{{ product_one.title | escape }}"
                width="64"
                height="64"
                loading="lazy"
              >
            {% endif %}
            <span class="bundle-offer__qty-chip">x1</span>
          </div>
          <div>
            <div class="bundle-offer__title-row">
              <span class="bundle-offer__title">{{ block.settings.offer_label_1 }}</span>
              {% if block.settings.best_seller_pack == '1' %}
                <span class="bundle-offer__pill">{{ block.settings.best_seller_text }}</span>
              {% endif %}
            </div>
            <div class="bundle-offer__price-row">
              <span class="bundle-offer__price" data-price-type="final">{{ subtotal_offer_1 | money }}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bundle-offer__details">
        <div
          class="bundle-offer-item"
          data-item-index="1"
          data-current-variant-id="{{ variant_one.id }}"
          data-current-price="{{ variant_one.price }}"
          data-item-label="{{ block.settings.item_1_label | escape }}"
        >
          <div class="bundle-offer-item__row">
            {% if image_one %}
              <img
                class="bundle-offer-item__image"
                data-item-image
                src="{{ image_one | image_url: width: 180 }}"
                alt="{{ product_one.title | escape }}"
                width="44"
                height="44"
                loading="lazy"
              >
            {% endif %}

            {% if block.settings.show_variant_picker %}
              <label class="bundle-offer-item__select-wrap">
                <span class="visually-hidden">{{ block.settings.item_1_label }}</span>
                <select class="bundle-variant-select" data-item-index="1">
                  {% for variant in product_one.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-price="{{ variant.price }}"
                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_one.featured_image %}{{ product_one.featured_image | image_url: width: 400 }}{% endif %}"
                      data-options='{{ variant.options | json | escape }}'
                      {% if variant.id == variant_one.id %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ product_one.title }} : {{ variant.title }}{% unless variant.available %} | Sold out{% endunless %}
                    </option>
                  {% endfor %}
                </select>
              </label>
            {% else %}
              <div class="bundle-offer-item__static">
                <span>{{ product_one.title }}</span>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {% if item_two_enabled %}
      <div
        class="bundle-offer"
        data-item-count="2"
        data-discount="{{ discount_2 }}"
        role="button"
        tabindex="0"
        aria-pressed="false"
      >
        <div class="bundle-offer__summary">
          <div class="bundle-offer__summary-left">
            {% assign image_two = variant_two.featured_image | default: product_two.featured_image %}
            <div class="bundle-offer__thumb-wrap">
              {% if image_one %}
                <img
                  class="bundle-offer__thumb"
                  src="{{ image_one | image_url: width: 220 }}"
                  alt="{{ product_one.title | escape }}"
                  width="64"
                  height="64"
                  loading="lazy"
                >
              {% endif %}
              <span class="bundle-offer__qty-chip">x2</span>
            </div>
            <div>
              <div class="bundle-offer__title-row">
                <span class="bundle-offer__title">{{ block.settings.offer_label_2 }}</span>
                {% if block.settings.best_seller_pack == '2' %}
                  <span class="bundle-offer__pill">{{ block.settings.best_seller_text }}</span>
                {% endif %}
                {% if block.settings.best_seller_pack != '2' and block.settings.best_seller_pack == 'none' %}
                {% endif %}
              </div>
              <div class="bundle-offer__price-row">
                <span class="bundle-offer__compare" data-price-type="compare">{{ subtotal_offer_2 | money }}</span>
                <span class="bundle-offer__price" data-price-type="final">{{ final_offer_2 | money }}</span>
                {% if discount_2 > 0 %}
                  <span class="bundle-offer__saving">{{ block.settings.save_badge_prefix }} {{ discount_2 }}%</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

        <div class="bundle-offer__details" hidden>
          <div
            class="bundle-offer-item"
            data-item-index="1"
            data-current-variant-id="{{ variant_one.id }}"
            data-current-price="{{ variant_one.price }}"
            data-item-label="{{ block.settings.item_1_label | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_one %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_one | image_url: width: 180 }}"
                  alt="{{ product_one.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ block.settings.item_1_label }}</span>
                  <select class="bundle-variant-select" data-item-index="1">
                    {% for variant in product_one.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-price="{{ variant.price }}"
                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_one.featured_image %}{{ product_one.featured_image | image_url: width: 400 }}{% endif %}"
                      data-options='{{ variant.options | json | escape }}'
                      {% if variant.id == variant_one.id %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ product_one.title }} : {{ variant.title }}{% unless variant.available %} | Sold out{% endunless %}
                    </option>
                  {% endfor %}
                </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="bundle-offer-item"
            data-item-index="2"
            data-current-variant-id="{{ variant_two.id }}"
            data-current-price="{{ variant_two.price }}"
            data-item-label="{{ product_one.title | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_two %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_two | image_url: width: 180 }}"
                  alt="{{ product_two.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.item_2_show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ block.settings.item_2_label }}</span>
                  <select class="bundle-variant-select" data-item-index="2">
                    {% for variant in product_two.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_two.featured_image %}{{ product_two.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_two.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if item_three_enabled %}
      <div
        class="bundle-offer"
        data-item-count="3"
        data-discount="{{ discount_3 }}"
        role="button"
        tabindex="0"
        aria-pressed="false"
      >
        <div class="bundle-offer__summary">
          <div class="bundle-offer__summary-left">
            <div class="bundle-offer__thumb-wrap">
              {% if image_one %}
                <img
                  class="bundle-offer__thumb"
                  src="{{ image_one | image_url: width: 220 }}"
                  alt="{{ product_one.title | escape }}"
                  width="64"
                  height="64"
                  loading="lazy"
                >
              {% endif %}
              <span class="bundle-offer__qty-chip">x3</span>
            </div>
            <div>
              <div class="bundle-offer__title-row">
                <span class="bundle-offer__title">{{ block.settings.offer_label_3 }}</span>
                {% if block.settings.best_seller_pack == '3' %}
                  <span class="bundle-offer__pill">{{ block.settings.best_seller_text }}</span>
                {% endif %}
              </div>
              <div class="bundle-offer__price-row">
                <span class="bundle-offer__compare" data-price-type="compare">{{ subtotal_offer_3 | money }}</span>
                <span class="bundle-offer__price" data-price-type="final">{{ final_offer_3 | money }}</span>
                {% if discount_3 > 0 %}
                  <span class="bundle-offer__saving">{{ block.settings.save_badge_prefix }} {{ discount_3 }}%</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

        <div class="bundle-offer__details" hidden>
          <div
            class="bundle-offer-item"
            data-item-index="1"
            data-current-variant-id="{{ variant_one.id }}"
            data-current-price="{{ variant_one.price }}"
            data-item-label="{{ block.settings.item_1_label | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_one %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_one | image_url: width: 180 }}"
                  alt="{{ product_one.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ block.settings.item_1_label }}</span>
                  <select class="bundle-variant-select" data-item-index="1">
                    {% for variant in product_one.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_one.featured_image %}{{ product_one.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_one.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="bundle-offer-item"
            data-item-index="2"
            data-current-variant-id="{{ variant_two.id }}"
            data-current-price="{{ variant_two.price }}"
            data-item-label="{{ product_one.title | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_two %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_two | image_url: width: 180 }}"
                  alt="{{ product_two.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.item_2_show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ block.settings.item_2_label }}</span>
                  <select class="bundle-variant-select" data-item-index="2">
                    {% for variant in product_two.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_two.featured_image %}{{ product_two.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_two.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="bundle-offer-item"
            data-item-index="3"
            data-current-variant-id="{{ variant_three.id }}"
            data-current-price="{{ variant_three.price }}"
            data-item-label="{{ product_one.title | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% assign image_three = variant_three.featured_image | default: product_three.featured_image %}
              {% if image_three %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_three | image_url: width: 180 }}"
                  alt="{{ product_three.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if block.settings.item_3_show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ block.settings.item_3_label }}</span>
                  <select class="bundle-variant-select" data-item-index="3">
                    {% for variant in product_three.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_three.featured_image %}{{ product_three.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_three.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>

  <button type="button" class="bundle-add-button">
    Add selected bundle
  </button>
  </div>
</div>

<style>
  .bundle-widget {
    --bundle-pill: #ffffff;
    --bundle-accent: #f1c500;
    display: grid;
    gap: 14px;
    color: var(--bundle-text);
  }

  .bundle-widget--soft {
    gap: 12px;
  }

  .bundle-widget--soft .bundle-offer {
    border-radius: 22px;
  }

  .bundle-widget--soft .bundle-add-button {
    background: color-mix(in srgb, var(--bundle-accent-base) 78%, black);
  }

  .bundle-widget--cards .bundle-offer {
    background: #ffffff;
    border-radius: 18px;
    border-color: color-mix(in srgb, var(--bundle-accent-base) 12%, #d7d7d7);
    box-shadow: 0 10px 24px rgba(18, 31, 14, 0.08);
  }

  .bundle-widget--cards .bundle-offer.is-selected {
    background: color-mix(in srgb, var(--bundle-accent-base) 8%, #ffffff);
    transform: translateY(-2px);
    box-shadow: 0 18px 34px rgba(18, 31, 14, 0.12);
  }

  .bundle-widget--cards .bundle-offer__title {
    font-size: 20px;
    letter-spacing: 0.01em;
  }

  .bundle-widget--cards .bundle-offer__price {
    font-size: 26px;
  }

  .bundle-widget--cards .bundle-variant-select,
  .bundle-widget--cards .bundle-offer-item__static {
    background: color-mix(in srgb, var(--bundle-accent-base) 10%, #ffffff);
    border: 1px solid color-mix(in srgb, var(--bundle-accent-base) 16%, #d9d9d9);
  }

  .bundle-widget--cards .bundle-add-button {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--bundle-accent-base) 72%, black) 0%,
      color-mix(in srgb, var(--bundle-accent-base) 88%, black) 100%
    );
  }

  .bundle-widget--outline .bundle-offer {
    background: transparent;
    border-width: 2px;
    border-style: dashed;
    border-color: color-mix(in srgb, var(--bundle-accent-base) 42%, white);
  }

  .bundle-widget--outline .bundle-offer.is-selected {
    background: color-mix(in srgb, var(--bundle-accent-base) 12%, white);
    box-shadow: none;
    border-style: solid;
    border-color: color-mix(in srgb, var(--bundle-accent-base) 70%, black);
  }

  .bundle-widget--outline .bundle-offer__thumb {
    border: 2px solid color-mix(in srgb, var(--bundle-accent-base) 34%, white);
  }

  .bundle-widget--outline .bundle-offer__price-row {
    gap: 10px;
  }

  .bundle-widget--outline .bundle-variant-select,
  .bundle-widget--outline .bundle-offer-item__static {
    background: transparent;
    border: 2px solid color-mix(in srgb, var(--bundle-accent-base) 36%, white);
  }

  .bundle-widget--outline .bundle-add-button {
    background: transparent;
    border: 2px solid color-mix(in srgb, var(--bundle-accent-base) 72%, black);
    color: var(--bundle-text);
  }

  .bundle-widget--minimal .bundle-widget__header {
    gap: 2px;
  }

  .bundle-widget--minimal .bundle-offer {
    border-radius: 14px;
    padding: 14px;
  }

  .bundle-widget--minimal .bundle-offer__thumb {
    border-radius: 12px;
  }

  .bundle-widget--minimal .bundle-offer__title {
    font-size: 18px;
  }

  .bundle-widget--minimal .bundle-offer__price {
    font-size: 20px;
  }

  .bundle-widget--minimal .bundle-offer__qty-chip,
  .bundle-widget--minimal .bundle-offer__saving,
  .bundle-widget--minimal .bundle-offer__pill {
    font-size: 11px;
    padding: 4px 10px;
  }

  .bundle-widget--minimal .bundle-offer__summary-left {
    align-items: flex-start;
  }

  .bundle-widget--minimal .bundle-variant-select,
  .bundle-widget--minimal .bundle-offer-item__static {
    min-height: 46px;
    border-radius: 10px;
    font-size: 15px;
  }

  .bundle-widget--minimal .bundle-add-button {
    min-height: 48px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--bundle-accent-base) 70%, black);
  }

  .bundle-widget--pills .bundle-offer {
    border-radius: 28px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--bundle-accent-base) 24%, white) 0%,
      color-mix(in srgb, var(--bundle-accent-base) 38%, white) 100%
    );
  }

  .bundle-widget--pills .bundle-offer__thumb,
  .bundle-widget--pills .bundle-offer-item__image {
    border-radius: 999px;
  }

  .bundle-widget--pills .bundle-variant-select,
  .bundle-widget--pills .bundle-offer-item__static,
  .bundle-widget--pills .bundle-add-button {
