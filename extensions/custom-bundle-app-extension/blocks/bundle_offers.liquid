      var(--bundle-timer-flap-bg-top, #191919) 0%,
      var(--bundle-timer-flap-bg, #111111) 49%,
      var(--bundle-timer-flap-divider, #050505) 50%,
      var(--bundle-timer-flap-bg-bottom, #1f1f1f) 100%
    );
