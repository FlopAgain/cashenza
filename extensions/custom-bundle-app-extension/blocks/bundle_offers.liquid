{% assign product_one = product %}
{% assign variant_one = product_one.selected_or_first_available_variant %}
{% assign product_two = product_one %}
{% assign product_three = product_one %}
{% assign best_seller_png_preset = block.settings.best_seller_png_badge_preset | default: 'none' %}
{% assign best_seller_png_asset = blank %}
{% assign bundle_item_count = '3' %}
{% assign item_two_enabled = false %}
{% assign item_three_enabled = false %}
{% assign best_seller_pack = '2' %}
{% assign best_seller_text = 'BEST SELLER' %}
{% assign offer_label_1 = '1 SET' %}
{% assign offer_label_2 = '2 SETS - PACK DUO' %}
{% assign offer_label_3 = '3 SETS - FULL BUNDLE' %}
{% assign item_1_label = 'Set 1' %}
{% assign item_2_label = 'Set 2' %}
{% assign item_3_label = 'Set 3' %}
{% assign show_variant_picker = true %}
{% assign item_2_show_variant_picker = true %}
{% assign item_3_show_variant_picker = true %}

{% case best_seller_png_preset %}
  {% when 'orange-ribbon' %}
    {% assign best_seller_png_asset = 'best-seller-orange-ribbon.png' | asset_url %}
  {% when 'blue-award' %}
    {% assign best_seller_png_asset = 'best-seller-blue-award.png' | asset_url %}
  {% when 'gold-award' %}
    {% assign best_seller_png_asset = 'best-seller-gold-award.png' | asset_url %}
  {% when 'pink-banner' %}
    {% assign best_seller_png_asset = 'best-seller-pink-banner.png' | asset_url %}
  {% when 'red-speech' %}
    {% assign best_seller_png_asset = 'best-seller-red-speech.png' | asset_url %}
  {% when 'red-stamp' %}
    {% assign best_seller_png_asset = 'best-seller-red-stamp.png' | asset_url %}
{% endcase %}

{% if bundle_item_count == '2' or bundle_item_count == '3' %}
  {% assign item_two_enabled = true %}
{% endif %}

{% if bundle_item_count == '3' %}
  {% assign item_three_enabled = true %}
{% endif %}

{% assign variant_two = blank %}
{% assign variant_three = blank %}

{% if item_two_enabled %}
  {% assign variant_two = variant_one %}
{% endif %}

{% if item_three_enabled %}
  {% assign variant_three = variant_one %}
{% endif %}

{% assign subtotal_offer_1 = variant_one.price %}
{% assign subtotal_offer_2 = subtotal_offer_1 %}
{% assign subtotal_offer_3 = subtotal_offer_2 %}

{% if item_two_enabled and variant_two %}
  {% assign subtotal_offer_2 = subtotal_offer_1 | plus: variant_two.price %}
  {% assign subtotal_offer_3 = subtotal_offer_2 %}
{% endif %}

{% if item_three_enabled and variant_three %}
  {% assign subtotal_offer_3 = subtotal_offer_2 | plus: variant_three.price %}
{% endif %}

{% assign discount_2 = 10 %}
{% assign discount_3 = 15 %}
{% assign discount_amount_2 = subtotal_offer_2 | times: discount_2 | divided_by: 100 %}
{% assign discount_amount_3 = subtotal_offer_3 | times: discount_3 | divided_by: 100 %}
{% assign final_offer_2 = subtotal_offer_2 | minus: discount_amount_2 %}
{% assign final_offer_3 = subtotal_offer_3 | minus: discount_amount_3 %}

<style data-cashenza-bundle-critical>
  .cashenza-bundle-loading :is(
    .buy-buttons-block,
    .product-form-buttons,
    .quantity-selector-wrapper,
    .accelerated-checkout-block,
    add-to-cart-component,
    product-form-component,
    product-form,
    .shopify-product-form,
    .product-form,
    .product-form__buttons,
    .shopify-payment-button,
    variant-picker,
    product-variant-picker,
    variant-radios,
    variant-selects,
    .product-form__input,
    .product__selectors,
    .product-form__submit,
    [data-testid="standalone-add-to-cart"]
  ):not(.bundle-widget *) {
    display: none !important;
  }
</style>

<script>
  (() => {
    document.documentElement.classList.add("cashenza-bundle-loading");
    document.body?.classList?.add("cashenza-bundle-loading");

    const currentScript = document.currentScript;
    const container =
      currentScript?.closest?.(".product-information") ||
      currentScript?.closest?.(".product-details") ||
      document.querySelector(".product-information") ||
      document.querySelector(".product-details");

    if (container) {
      container.classList.add("cashenza-bundle-loading");
    }

    window.setTimeout(() => {
      if (document.documentElement.dataset.cashenzaBundleState !== "active") {
        document.documentElement.dataset.cashenzaBundleState = "timeout";
        document.documentElement.classList.add("cashenza-bundle-ready");
        document.documentElement.classList.remove("cashenza-bundle-loading");
        document.body?.classList?.remove("cashenza-bundle-loading");
        container?.classList?.remove("cashenza-bundle-loading");
      }
    }, 2200);
  })();
</script>

<div
  class="bundle-widget bundle-widget--{{ block.settings.design_preset }}"
  id="bundle-widget-{{ block.id }}"
  hidden
  data-bundle-visibility="pending"
  data-best-seller-preset="{{ block.settings.best_seller_badge_preset }}"
  {{ block.shopify_attributes }}
  style="
    --bundle-accent-base: {{ block.settings.primary_color }};
    --bundle-bg: color-mix(in srgb, {{ block.settings.primary_color }} 20%, white);
    --bundle-bg-selected: color-mix(in srgb, {{ block.settings.primary_color }} 30%, white);
    --bundle-border: color-mix(in srgb, {{ block.settings.primary_color }} 22%, white);
    --bundle-input: color-mix(in srgb, {{ block.settings.primary_color }} 42%, white);
    --bundle-text: {{ block.settings.text_color }};
    --bundle-heading-size: {{ block.settings.heading_size }}px;
    --bundle-subheading-size: {{ block.settings.subheading_size }}px;
    --bundle-offer-title-size: {{ block.settings.offer_title_size }}px;
    --bundle-offer-price-size: {{ block.settings.offer_price_size }}px;
    --bundle-card-gap: {{ block.settings.card_gap }}px;
    --bundle-card-padding: {{ block.settings.card_padding }}px;
    --bundle-card-radius: 24px;
    --bundle-bestseller-bg: {{ block.settings.best_seller_badge_color }};
    --bundle-bestseller-text: {{ block.settings.best_seller_badge_text_color }};
    --bundle-save-bg: {{ block.settings.save_badge_color }};
    --bundle-save-text: {{ block.settings.save_badge_text_color }};
    --bundle-timer-bg: {{ block.settings.timer_background_color }};
    --bundle-timer-text: {{ block.settings.timer_text_color }};
    --bundle-offer-count: 3;
  "
>
  <script type="application/json" data-bundle-config>
    {
      "locale": {{ request.locale.iso_code | json }},
      "currencyCode": {{ cart.currency.iso_code | json }},
      "productHandle": {{ product.handle | json }},
      "proxyUrl": {{ "/apps/custom-bundles/bundles?product_handle=" | append: product.handle | append: "&shop=" | append: shop.permanent_domain | append: "&limit=1" | json }},
      "analyticsUrl": {{ "/apps/custom-bundles/analytics?shop=" | append: shop.permanent_domain | json }},
      "themeEffectsPreset": {{ block.settings.effects_preset | default: 'fade in' | json }},
      "themeTimerPreset": {{ block.settings.timer_preset | json }},
      "themeBadgeAppearance": {
        "bestSellerBadgePreset": {{ block.settings.best_seller_badge_preset | json }},
        "bestSellerPngBadgePreset": {{ block.settings.best_seller_png_badge_preset | json }},
        "bestSellerBadgeColor": {{ block.settings.best_seller_badge_color | json }},
        "bestSellerBadgeText": {{ block.settings.best_seller_badge_text_color | json }},
        "saveBadgeColor": {{ block.settings.save_badge_color | json }},
        "saveBadgeText": {{ block.settings.save_badge_text_color | json }},
        "saveBadgePrefix": {{ block.settings.save_badge_prefix | json }}
      },
      "bestSellerPngAssets": {
        "orange-ribbon": {{ 'best-seller-orange-ribbon.png' | asset_url | json }},
        "blue-award": {{ 'best-seller-blue-award.png' | asset_url | json }},
        "gold-award": {{ 'best-seller-gold-award.png' | asset_url | json }},
        "pink-banner": {{ 'best-seller-pink-banner.png' | asset_url | json }},
        "red-speech": {{ 'best-seller-red-speech.png' | asset_url | json }},
        "red-stamp": {{ 'best-seller-red-stamp.png' | asset_url | json }}
      }
    }
  </script>
  <div class="bundle-widget__topbar">
    {% if block.settings.eyebrow != blank or block.settings.heading != blank %}
      <div class="bundle-widget__header">
        {% if block.settings.eyebrow != blank %}
          <p class="bundle-widget__eyebrow">{{ block.settings.eyebrow }}</p>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h2 class="bundle-widget__title">{{ block.settings.heading }}</h2>
        {% endif %}
        {% if block.settings.subheading != blank %}
          <p class="bundle-widget__subheading">{{ block.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

  <div
    class="bundle-widget__timer bundle-widget__timer--{{ block.settings.timer_preset }}"
    data-bundle-timer
    data-end=""
    data-prefix="{{ block.settings.timer_prefix | escape }}"
    data-expired-label="{{ block.settings.timer_expired_text | escape }}"
      {% unless block.settings.show_timer %}hidden{% endunless %}
    >
      <span class="bundle-widget__timer-label">{{ block.settings.timer_prefix }}</span>
      <span class="bundle-widget__timer-value">--:--:--</span>
    </div>
  </div>

  <div class="bundle-dynamic-root" id="bundle-dynamic-root-{{ block.id }}" hidden></div>

  <div class="bundle-static-root" data-static-root hidden>
  <div class="bundle-offers">
    <div
      class="bundle-offer is-selected"
      data-item-count="1"
      data-discount="0"
      role="button"
      tabindex="0"
      aria-pressed="true"
      style="--bundle-offer-index: 0;"
    >
      <div class="bundle-offer__summary">
        <div class="bundle-offer__summary-left">
          {% assign image_one = variant_one.featured_image | default: product_one.featured_image %}
          <div class="bundle-offer__thumb-wrap">
            {% if image_one %}
              <img
                class="bundle-offer__thumb"
                src="{{ image_one | image_url: width: 220 }}"
                alt="{{ product_one.title | escape }}"
                width="64"
                height="64"
                loading="lazy"
              >
            {% endif %}
            <span class="bundle-offer__qty-chip">x1</span>
          </div>
          <div>
            <div class="bundle-offer__title-row{% if best_seller_pack == '1' and best_seller_png_asset != blank %} bundle-offer__title-row--has-png{% endif %}">
              <span class="bundle-offer__title">{{ offer_label_1 }}</span>
                {% if best_seller_pack == '1' %}
                  {% if best_seller_png_asset != blank %}
                    <img
                      class="bundle-offer__pill-image bundle-offer__pill-image--{{ best_seller_png_preset }}"
                      src="{{ best_seller_png_asset }}"
                      alt="{{ best_seller_text | escape }}"
                      width="96"
                      height="96"
                      loading="lazy"
                    >
                  {% else %}
                    <span class="bundle-offer__pill bundle-offer__pill--{{ block.settings.best_seller_badge_preset }}">{{ best_seller_text }}</span>
                  {% endif %}
                {% endif %}
            </div>
            <div class="bundle-offer__price-row">
              <span class="bundle-offer__price" data-price-type="final">{{ subtotal_offer_1 | money }}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="bundle-offer__details">
        <div
          class="bundle-offer-item"
          data-item-index="1"
          data-current-variant-id="{{ variant_one.id }}"
          data-current-price="{{ variant_one.price }}"
          data-item-label="{{ item_1_label | escape }}"
        >
          <div class="bundle-offer-item__row">
            {% if image_one %}
              <img
                class="bundle-offer-item__image"
                data-item-image
                src="{{ image_one | image_url: width: 180 }}"
                alt="{{ product_one.title | escape }}"
                width="44"
                height="44"
                loading="lazy"
              >
            {% endif %}

            {% if show_variant_picker %}
              <label class="bundle-offer-item__select-wrap">
                <span class="visually-hidden">{{ item_1_label }}</span>
                <select class="bundle-variant-select" data-item-index="1">
                  {% for variant in product_one.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-price="{{ variant.price }}"
                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_one.featured_image %}{{ product_one.featured_image | image_url: width: 400 }}{% endif %}"
                      data-options='{{ variant.options | json | escape }}'
                      {% if variant.id == variant_one.id %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ product_one.title }} : {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} | Sold out{% endunless %}
                    </option>
                  {% endfor %}
                </select>
              </label>
            {% else %}
              <div class="bundle-offer-item__static">
                <span>{{ product_one.title }}</span>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    {% if item_two_enabled %}
      <div
        class="bundle-offer"
        data-item-count="2"
        data-discount="{{ discount_2 }}"
        role="button"
        tabindex="0"
        aria-pressed="false"
        style="--bundle-offer-index: 1;"
      >
        <div class="bundle-offer__summary">
          <div class="bundle-offer__summary-left">
            {% assign image_two = variant_two.featured_image | default: product_two.featured_image %}
            <div class="bundle-offer__thumb-wrap">
              {% if image_one %}
                <img
                  class="bundle-offer__thumb"
                  src="{{ image_one | image_url: width: 220 }}"
                  alt="{{ product_one.title | escape }}"
                  width="64"
                  height="64"
                  loading="lazy"
                >
              {% endif %}
              <span class="bundle-offer__qty-chip">x2</span>
            </div>
            <div>
              <div class="bundle-offer__title-row{% if best_seller_pack == '2' and best_seller_png_asset != blank %} bundle-offer__title-row--has-png{% endif %}">
                <span class="bundle-offer__title">{{ offer_label_2 }}</span>
                  {% if best_seller_pack == '2' %}
                    {% if best_seller_png_asset != blank %}
                    <img
                      class="bundle-offer__pill-image bundle-offer__pill-image--{{ best_seller_png_preset }}"
                      src="{{ best_seller_png_asset }}"
                      alt="{{ best_seller_text | escape }}"
                      width="96"
                      height="96"
                      loading="lazy"
                    >
                  {% else %}
                    <span class="bundle-offer__pill bundle-offer__pill--{{ block.settings.best_seller_badge_preset }}">{{ best_seller_text }}</span>
                  {% endif %}
                {% endif %}
                {% if best_seller_pack != '2' and best_seller_pack == 'none' %}
                {% endif %}
              </div>
              <div class="bundle-offer__price-row">
                <span class="bundle-offer__compare" data-price-type="compare">{{ subtotal_offer_2 | money }}</span>
                <span class="bundle-offer__price" data-price-type="final">{{ final_offer_2 | money }}</span>
                {% if discount_2 > 0 %}
                  <span class="bundle-offer__saving">{{ block.settings.save_badge_prefix }} {{ discount_2 }}%</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

        <div class="bundle-offer__details" hidden>
          <div
            class="bundle-offer-item"
            data-item-index="1"
            data-current-variant-id="{{ variant_one.id }}"
            data-current-price="{{ variant_one.price }}"
            data-item-label="{{ item_1_label | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_one %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_one | image_url: width: 180 }}"
                  alt="{{ product_one.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ item_1_label }}</span>
                  <select class="bundle-variant-select" data-item-index="1">
                    {% for variant in product_one.variants %}
                    <option
                      value="{{ variant.id }}"
                      data-price="{{ variant.price }}"
                      data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_one.featured_image %}{{ product_one.featured_image | image_url: width: 400 }}{% endif %}"
                      data-options='{{ variant.options | json | escape }}'
                      {% if variant.id == variant_one.id %}selected{% endif %}
                      {% unless variant.available %}disabled{% endunless %}
                    >
                      {{ product_one.title }} : {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} | Sold out{% endunless %}
                    </option>
                  {% endfor %}
                </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="bundle-offer-item"
            data-item-index="2"
            data-current-variant-id="{{ variant_two.id }}"
            data-current-price="{{ variant_two.price }}"
            data-item-label="{{ product_one.title | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_two %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_two | image_url: width: 180 }}"
                  alt="{{ product_two.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if item_2_show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ item_2_label }}</span>
                  <select class="bundle-variant-select" data-item-index="2">
                    {% for variant in product_two.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_two.featured_image %}{{ product_two.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_two.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    {% if item_three_enabled %}
      <div
        class="bundle-offer"
        data-item-count="3"
        data-discount="{{ discount_3 }}"
        role="button"
        tabindex="0"
        aria-pressed="false"
        style="--bundle-offer-index: 2;"
      >
        <div class="bundle-offer__summary">
          <div class="bundle-offer__summary-left">
            <div class="bundle-offer__thumb-wrap">
              {% if image_one %}
                <img
                  class="bundle-offer__thumb"
                  src="{{ image_one | image_url: width: 220 }}"
                  alt="{{ product_one.title | escape }}"
                  width="64"
                  height="64"
                  loading="lazy"
                >
              {% endif %}
              <span class="bundle-offer__qty-chip">x3</span>
            </div>
            <div>
              <div class="bundle-offer__title-row{% if best_seller_pack == '3' and best_seller_png_asset != blank %} bundle-offer__title-row--has-png{% endif %}">
                <span class="bundle-offer__title">{{ offer_label_3 }}</span>
                  {% if best_seller_pack == '3' %}
                    {% if best_seller_png_asset != blank %}
                    <img
                      class="bundle-offer__pill-image bundle-offer__pill-image--{{ best_seller_png_preset }}"
                      src="{{ best_seller_png_asset }}"
                      alt="{{ best_seller_text | escape }}"
                      width="96"
                      height="96"
                      loading="lazy"
                    >
                  {% else %}
                    <span class="bundle-offer__pill bundle-offer__pill--{{ block.settings.best_seller_badge_preset }}">{{ best_seller_text }}</span>
                  {% endif %}
                {% endif %}
              </div>
              <div class="bundle-offer__price-row">
                <span class="bundle-offer__compare" data-price-type="compare">{{ subtotal_offer_3 | money }}</span>
                <span class="bundle-offer__price" data-price-type="final">{{ final_offer_3 | money }}</span>
                {% if discount_3 > 0 %}
                  <span class="bundle-offer__saving">{{ block.settings.save_badge_prefix }} {{ discount_3 }}%</span>
                {% endif %}
              </div>
            </div>
          </div>
        </div>

        <div class="bundle-offer__details" hidden>
          <div
            class="bundle-offer-item"
            data-item-index="1"
            data-current-variant-id="{{ variant_one.id }}"
            data-current-price="{{ variant_one.price }}"
            data-item-label="{{ item_1_label | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_one %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_one | image_url: width: 180 }}"
                  alt="{{ product_one.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ item_1_label }}</span>
                  <select class="bundle-variant-select" data-item-index="1">
                    {% for variant in product_one.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_one.featured_image %}{{ product_one.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_one.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="bundle-offer-item"
            data-item-index="2"
            data-current-variant-id="{{ variant_two.id }}"
            data-current-price="{{ variant_two.price }}"
            data-item-label="{{ product_one.title | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% if image_two %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_two | image_url: width: 180 }}"
                  alt="{{ product_two.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if item_2_show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ item_2_label }}</span>
                  <select class="bundle-variant-select" data-item-index="2">
                    {% for variant in product_two.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_two.featured_image %}{{ product_two.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_two.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>

          <div
            class="bundle-offer-item"
            data-item-index="3"
            data-current-variant-id="{{ variant_three.id }}"
            data-current-price="{{ variant_three.price }}"
            data-item-label="{{ product_one.title | escape }}"
          >
            <div class="bundle-offer-item__row">
              {% assign image_three = variant_three.featured_image | default: product_three.featured_image %}
              {% if image_three %}
                <img
                  class="bundle-offer-item__image"
                  data-item-image
                  src="{{ image_three | image_url: width: 180 }}"
                  alt="{{ product_three.title | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {% endif %}
              {% if item_3_show_variant_picker %}
                <label class="bundle-offer-item__select-wrap">
                  <span class="visually-hidden">{{ item_3_label }}</span>
                  <select class="bundle-variant-select" data-item-index="3">
                    {% for variant in product_three.variants %}
                      <option
                        value="{{ variant.id }}"
                        data-price="{{ variant.price }}"
                        data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 400 }}{% elsif product_three.featured_image %}{{ product_three.featured_image | image_url: width: 400 }}{% endif %}"
                        data-options='{{ variant.options | json | escape }}'
                        {% if variant.id == variant_three.id %}selected{% endif %}
                        {% unless variant.available %}disabled{% endunless %}
                      >
                        {{ product_one.title }} : {{ variant.title }} - {{ variant.price | money }}{% unless variant.available %} | Sold out{% endunless %}
                      </option>
                    {% endfor %}
                  </select>
                </label>
              {% else %}
                <div class="bundle-offer-item__static">
                  <span>{{ product_one.title }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}
  </div>

